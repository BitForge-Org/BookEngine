                    "raw": "{\n  \"displayName\": \"Dr. Rajesh Mehta\",\n  \"description\": \"Updated description for provider profile\",\n  \"website\": \"https://updated-mehtadentalcare.com\",\n  \"contactInfo\": {\n    \"email\": \"updated-drraj@example.com\",\n    \"phone\": \"+919999999999\"\n  },\n  \"location\": {\n    \"address\": \"456 FC Road\",\n    \"city\": \"Pune\",\n    \"state\": \"Maharashtra\",\n    \"zip\": \"411001\",\n    \"country\": \"India\"\n  }\n}"
