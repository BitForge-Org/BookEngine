    "item": [
        {
            "name": "Create Provider",
            "request": {
                "method": "POST",
                "header": [
                    {
                        "key": "Content-Type",
                        "value": "application/json"
                    }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n  \"displayName\": \"Dr. Raj Mehta\",\n  \"businessName\": \"Mehta Dental Care\",\n  \"providerType\": \"doctor\",\n  \"providerBusiness\": \"clinic\",\n  \"bookingSlug\": \"dr-raj-mehta\",\n  \"logoUrl\": \"https://example.com/logo.png\",\n  \"bannerUrl\": \"https://example.com/banner.png\",\n  \"description\": \"Experienced dental surgeon with 10+ years of practice.\",\n  \"website\": \"https://mehtadentalcare.com\",\n  \"socialLinks\": [\n    {\n      \"platform\": \"instagram\",\n      \"url\": \"https://instagram.com/drrajmehta\"\n    },\n    {\n      \"platform\": \"facebook\",\n      \"url\": \"https://facebook.com/drrajmehta\"\n    }\n  ],\n  \"contactInfo\": {\n    \"email\": \"drraj@example.com\",\n    \"phone\": \"+919876543210\"\n  },\n  \"location\": {\n    \"address\": \"123 MG Road\",\n    \"city\": \"Pune\",\n    \"state\": \"Maharashtra\",\n    \"zip\": \"411014\",\n    \"country\": \"India\"\n  },\n  \"timezone\": \"Asia/Kolkata\"\n}"
                },
                "url": {
                    "raw": "{{baseUrl}}/providers",
                    "host": [
                        "{{baseUrl}}"
                    ],
                    "path": [
                        "providers"
                    ]
                }
            }
        },
        {
            "name": "Get All Providers",
            "request": {
                "method": "GET",
                "url": {
                    "raw": "{{baseUrl}}/providers?page=1&limit=10",
                    "host": [
                        "{{baseUrl}}"
                    ],
                    "path": [
                        "providers"
                    ],
                    "query": [
                        {
                            "key": "page",
                            "value": "1"
                        },
                        {
                            "key": "limit",
                            "value": "10"
                        }
                    ]
                }
            }
        },
        {
            "name": "Get All Providers With Filters",
            "request": {
                "method": "GET",
                "url": {
                    "raw": "{{baseUrl}}/providers?page=1&limit=10&providerType=doctor&status=active&isActive=true",
                    "host": [
                        "{{baseUrl}}"
                    ],
                    "path": [
                        "providers"
                    ],
                    "query": [
                        {
                            "key": "page",
                            "value": "1"
                        },
                        {
                            "key": "limit",
                            "value": "10"
                        },
                        {
                            "key": "providerType",
                            "value": "doctor"
                        },
                        {
                            "key": "status",
                            "value": "active"
                        },
                        {
                            "key": "isActive",
                            "value": "true"
                        }
                    ]
                }
            }
        },
        {
            "name": "Get Provider By ID",
            "request": {
                "method": "GET",
                "url": {
                    "raw": "{{baseUrl}}/providers/{{providerId}}",
                    "host": [
                        "{{baseUrl}}"
                    ],
                    "path": [
                        "providers",
                        "{{providerId}}"
                    ]
                }
            }
        },
        {
            "name": "Get Provider By Slug",
            "request": {
                "method": "GET",
                "url": {
                    "raw": "{{baseUrl}}/providers/slug/{{providerSlug}}",
                    "host": [
                        "{{baseUrl}}"
                    ],
                    "path": [
                        "providers",
                        "slug",
                        "{{providerSlug}}"
                    ]
                }
            }
        },
        {
            "name": "Get Public Provider By Slug",
            "request": {
                "method": "GET",
                "url": {
